# ============================================================
# BOLÃO BANDIDOS APOSTADOS — VARIÁVEIS DE AMBIENTE
#
# Local:   copie para .env e preencha (NUNCA commitar o .env)
# Netlify: cadastre TODAS em Site configuration > Environment variables
# ============================================================

# ---------- FRONTEND (expostas no navegador — só chaves públicas!) ----------

# Supabase > Project Settings > Data API > Project URL
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Supabase > Project Settings > API Keys > anon / public
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...sua-anon-key

# ---------- NETLIFY FUNCTIONS (servidor — nunca aparecem no navegador) ----------

# Mesmo Project URL acima
SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Supabase > Project Settings > API Keys > service_role
# ⚠️ SECRETA: ignora todas as regras de segurança do banco. Só em variável de ambiente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...sua-service-role-key

# Chave GRATUITA da API de jogos da Copa 2026.
# Registre em: https://www.football-data.org/client/register
# (a key chega por e-mail na hora; o plano free cobre a FIFA World Cup)
FOOTBALL_DATA_API_KEY=sua-key-da-football-data
